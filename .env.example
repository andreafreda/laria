# LARIA — example configuration. Copy to `.env` and fill in. Never commit `.env`.

# --- Core ---
LARIA_DATA_DIR=./data
LARIA_DB_PATH=./data/laria.db
LARIA_LOG_LEVEL=info

# --- LLM provider (phase 1: anthropic) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-8
# Future providers (placeholders):
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

# --- Messaging ---
TELEGRAM_TOKEN=

# --- Home Assistant integration (optional) ---
HA_ENABLED=false
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
# MQTT (for HA sensors/dashboards)
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Web UI ---
WEB_HOST=0.0.0.0
WEB_PORT=8080
