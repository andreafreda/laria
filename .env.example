# LARIA: example configuration. Copy to `.env` and fill in. Never commit `.env`.

# --- Core ---
LARIA_DATA_DIR=./data
LARIA_DB_PATH=./data/laria.db
LARIA_LOG_LEVEL=info

# --- LLM provider ---
# LLM_PROVIDER: anthropic | openai | openai-compatible | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
LLM_MAX_TOKENS=4096
# Fill in the key for the provider you choose. Only the active one is required.
ANTHROPIC_API_KEY=
# OpenAI or any OpenAI-compatible server (LM Studio, vLLM):
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Local Ollama (no key needed):
OLLAMA_BASE_URL=http://localhost:11434

# --- Agent memory ---
# MEMORY_BACKEND: fake (in-memory, default) | mem0
MEMORY_BACKEND=fake
MEMORY_EMBEDDER=fake
MEMORY_STORE_PATH=./data/memory

# --- Nutrition lookups (optional) ---
# USDA FoodData Central key; DEMO_KEY works but is rate-limited.
USDA_API_KEY=DEMO_KEY

# --- Auth ---
# Strong random secret that signs login tokens (change in production).
LARIA_JWT_SECRET=
LARIA_TOKEN_TTL_SECONDS=86400
# Owner account created on first run (then manage users from the app).
LARIA_ADMIN_USER=owner
LARIA_ADMIN_PASSWORD=

# --- Messaging ---
TELEGRAM_TOKEN=

# --- Home Assistant integration (optional) ---
HA_ENABLED=false
HA_URL=http://homeassistant.local:8123
HA_TOKEN=
# MQTT (for mirroring LARIA data as HA sensors/dashboards)
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# HA discovery root (match HA config; standard "homeassistant").
MQTT_DISCOVERY_PREFIX=homeassistant
# Namespaces LARIA's entities so they never collide with another publisher
# (e.g. HARIA) on the same broker. Change per migration if needed.
MQTT_NODE_ID=laria

# --- Web UI ---
WEB_HOST=0.0.0.0
WEB_PORT=8080
