# Keep the build context small and free of secrets and local state.
.git
.gitignore
.env
*.env
docs/
connector-ha/
# UI source is needed for the build stage; only skip its heavy/generated dirs.
ui/node_modules/
ui/www/
ui/.angular/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/tests/
data/
*.db
*.sqlite
node_modules/
.claude/
