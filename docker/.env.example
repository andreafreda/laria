# Copy to `.env` next to compose.nas.yaml on the NAS and fill in the values.
# `.env` is gitignored: real secrets never go in the repo.

# LLM provider (Anthropic API key billing).
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot (a bot separate from HARIA's).
TELEGRAM_TOKEN=123456:AA...
# One-time onboarding: send "/claim <this code>" from the chat to link the owner.
LARIA_TELEGRAM_CLAIM_CODE=change-me

# Owner account seeded on first run. Use real values, not the demo ones.
LARIA_ADMIN_USER=andrea
LARIA_ADMIN_PASSWORD=change-me-strong
# Signs login tokens: a long random string.
LARIA_JWT_SECRET=change-me-random

# Home Assistant control (optional). Long-lived token from HA profile.
HA_ENABLED=true
HA_URL=http://192.168.1.32:8123
HA_TOKEN=eyJ...
